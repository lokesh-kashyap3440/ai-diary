FROM node:22-alpine AS base
WORKDIR /app

COPY package.json package-lock.json tsconfig.base.json ./
COPY prisma ./prisma
COPY apps/api ./apps/api
COPY apps/web ./apps/web
COPY packages ./packages

RUN npm ci
RUN npm run prisma:generate
RUN npm run build -w @ai-diary/types
RUN npm run build -w @ai-diary/api

EXPOSE 4000

CMD ["sh", "-c", "npx prisma db push --schema prisma/schema.prisma && npm run start -w @ai-diary/api"]
