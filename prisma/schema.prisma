generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ReflectionStatus {
  pending
  completed
  failed
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  displayName     String?
  passwordHash    String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  magicLinkTokens MagicLinkToken[]
  diaryEntries    DiaryEntry[]
  chatThreads     ChatThread[]
  reminderSetting ReminderSetting?
}

model MagicLinkToken {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model DiaryEntry {
  id          String            @id @default(cuid())
  userId      String
  title       String
  body        String
  moodScore   Int?
  isDraft     Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  reflectedAt DateTime?
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  reflections EntryReflection[]
  tags        EntryTag[]

  @@index([userId, createdAt(sort: Desc)])
}

model EntryReflection {
  id                 String           @id @default(cuid())
  entryId            String
  status             ReflectionStatus @default(pending)
  summary            String?
  moodInterpretation String?
  themes             Json?
  prompts            Json?
  rawPayload         Json?
  errorMessage       String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  entry              DiaryEntry       @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId, createdAt(sort: Desc)])
}

model EntryTag {
  id      String     @id @default(cuid())
  entryId String
  label   String
  entry   DiaryEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@unique([entryId, label])
}

model ChatThread {
  id        String        @id @default(cuid())
  userId    String
  title     String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]

  @@index([userId, updatedAt(sort: Desc)])
}

model ChatMessage {
  id         String      @id @default(cuid())
  threadId    String
  role        String
  content     String
  relatedEntryId String?
  createdAt   DateTime   @default(now())
  thread      ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

model ReminderSetting {
  id        String   @id @default(cuid())
  userId    String   @unique
  enabled   Boolean  @default(false)
  hour      Int      @default(20)
  timezone  String   @default("UTC")
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
